{
  "project": {
    "name": "Arabic ERP UI Theme System",
    "direction": "rtl",
    "language": "ar",
    "goal": "Create a complete professional ERP interface theme system with light/dark modes and Palestinian/Gulf visual variants without duplicating or stacking old styles."
  },
  "global_rules": {
    "rtl_required": true,
    "remove_conflicting_old_styles": true,
    "no_duplicate_css": true,
    "use_design_tokens": true,
    "responsive_required": true,
    "supported_viewports": ["desktop", "tablet", "mobile"],
    "text_spacing": "comfortable",
    "minimum_input_height_px": 44,
    "minimum_button_height_px": 44,
    "border_radius": "12px",
    "font_family": "Tajawal, Cairo, system-ui, sans-serif"
  },
  "themes": {
    "palestinian_light": {
      "name": "Palestinian Light",
      "mode": "light",
      "background": "#F8F7F2",
      "surface": "#FFFFFF",
      "surface_alt": "#F1F5F1",
      "primary": "#006B3F",
      "primary_dark": "#004C2F",
      "secondary": "#111827",
      "accent": "#C8102E",
      "gold": "#C9A227",
      "text": "#111827",
      "muted_text": "#6B7280",
      "border": "#E5E7EB",
      "success": "#0E9F6E",
      "warning": "#D97706",
      "danger": "#DC2626",
      "info": "#2563EB",
      "pattern": "subtle_palestinian_embroidery"
    },
    "palestinian_dark": {
      "name": "Palestinian Dark",
      "mode": "dark",
      "background": "#0B0F0E",
      "surface": "#111827",
      "surface_alt": "#17201C",
      "primary": "#00A651",
      "primary_dark": "#007A3D",
      "secondary": "#F9FAFB",
      "accent": "#E11D48",
      "gold": "#D6B25E",
      "text": "#F9FAFB",
      "muted_text": "#A1A1AA",
      "border": "#263238",
      "success": "#22C55E",
      "warning": "#F59E0B",
      "danger": "#EF4444",
      "info": "#60A5FA",
      "pattern": "subtle_palestinian_embroidery"
    },
    "gulf_light": {
      "name": "Gulf Light",
      "mode": "light",
      "background": "#FAF8F2",
      "surface": "#FFFFFF",
      "surface_alt": "#F4F7F8",
      "primary": "#063B5B",
      "primary_dark": "#022A44",
      "secondary": "#0F766E",
      "accent": "#C9A24A",
      "gold": "#B88A2E",
      "text": "#0F172A",
      "muted_text": "#64748B",
      "border": "#E2E8F0",
      "success": "#059669",
      "warning": "#D97706",
      "danger": "#DC2626",
      "info": "#0284C7",
      "pattern": "subtle_gulf_geometric"
    },
    "gulf_dark": {
      "name": "Gulf Dark",
      "mode": "dark",
      "background": "#07111F",
      "surface": "#0D1B2A",
      "surface_alt": "#10263A",
      "primary": "#0F766E",
      "primary_dark": "#115E59",
      "secondary": "#D4AF37",
      "accent": "#C89B3C",
      "gold": "#D6B25E",
      "text": "#F8FAFC",
      "muted_text": "#CBD5E1",
      "border": "#1E3A4C",
      "success": "#10B981",
      "warning": "#F59E0B",
      "danger": "#F43F5E",
      "info": "#38BDF8",
      "pattern": "subtle_gulf_geometric"
    }
  },
  "css_files": [
    "static/css/gm-theme-tokens.css",
    "static/css/gm-design-system.css",
    "static/css/gm-spacing-dropdowns.css",
    "static/css/gm-theme-components.css",
    "static/css/gm-conflict-guard.css"
  ]
}
